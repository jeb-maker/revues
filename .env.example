# Revues — variables d'environnement
# Copier vers .env (ne pas committer)

# Serveur
REVUES_ADDR=:8080
REVUES_BASE_URL=http://localhost:8080

# Base de données
REVUES_DATABASE_PATH=data/revues.db

# Sécurité
REVUES_SESSION_SECRET=change-me-32-random-bytes-minimum
REVUES_ENCRYPTION_KEY=change-me-32-bytes-base64-for-aes-256-gcm

# GitHub OAuth
REVUES_GITHUB_CLIENT_ID=
REVUES_GITHUB_CLIENT_SECRET=

# Bootstrap admin (premier démarrage)
REVUES_BOOTSTRAP_ADMIN_EMAIL=

# Pièces jointes
REVUES_ATTACHMENTS_DIR=data/attachments

# Environnement
REVUES_ENV=development

# Auth démo locale (jamais en production) — bypass OAuth GitHub
# Uniquement si la requête vient de 127.0.0.1 / localhost (peer + Host).
# REVUES_DEV_AUTH=1
# REVUES_DEV_AUTH_EMAIL=admin@example.com
